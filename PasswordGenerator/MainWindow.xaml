<Window x:Class="PasswordGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Password Generator"
        Icon="Resources/password_generator.ico"
        Width="440"
        SizeToContent="Height"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundGray}">
  <StackPanel Margin="16">

    <!-- Result card -->
    <Border Style="{StaticResource CardBorder}" Background="White">
      <StackPanel>
        <Border Style="{StaticResource CardHeader}">
          <TextBlock Text="GENERATED PASSWORD" Style="{StaticResource CardHeaderText}"/>
        </Border>
        <StackPanel Style="{StaticResource CardContent}">
          <Grid>
            <TextBox x:Name="PasswordTextBox" FontFamily="Consolas" FontSize="15" IsReadOnly="True" Padding="8,6,36,6"/>
            <Button x:Name="CopyButton" Click="CopyButton_Click"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Width="28" Height="28" Margin="0,0,4,0"
                    ToolTip="Copy to clipboard" Style="{x:Null}">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="IconBorder" Background="Transparent" CornerRadius="4">
                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                               Foreground="#888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="IconBorder" Property="Background" Value="#EEEEEE"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
          </Grid>
          <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock Text="Entropy" Style="{StaticResource DecisionLabel}" Width="90"/>
            <TextBlock x:Name="EntropyTextBlock" Style="{StaticResource DecisionValue}" Margin="6,0,0,0"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
            <TextBlock Text="Search space" Style="{StaticResource DecisionLabel}" Width="90"/>
            <TextBlock x:Name="SearchSpaceTextBlock" Style="{StaticResource DecisionValue}" Margin="6,0,0,0"/>
          </StackPanel>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Length card -->
    <Border Style="{StaticResource CardBorder}" Background="White">
      <StackPanel>
        <Border Style="{StaticResource CardHeader}">
          <TextBlock Text="LENGTH" Style="{StaticResource CardHeaderText}"/>
        </Border>
        <StackPanel Style="{StaticResource CardContent}">
          <TextBox x:Name="LengthTextBox" Width="56" Padding="4,6" TextAlignment="Center" HorizontalAlignment="Left"
                   Text="16" TextChanged="LengthTextBox_TextChanged"
                   MouseEnter="LengthHoverArea_MouseEnter" MouseLeave="LengthHoverArea_MouseLeave"/>

          <Popup x:Name="LengthSliderPopup" PlacementTarget="{Binding ElementName=LengthTextBox}"
                 Placement="Bottom" HorizontalOffset="-75" VerticalOffset="4"
                 AllowsTransparency="True" PopupAnimation="Fade" StaysOpen="True">
            <Border Background="White" BorderBrush="{StaticResource BorderGray}" BorderThickness="1"
                    CornerRadius="6" Padding="12,10"
                    MouseEnter="LengthHoverArea_MouseEnter" MouseLeave="LengthHoverArea_MouseLeave">
              <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.2"/>
              </Border.Effect>
              <Slider x:Name="LengthSlider" Width="180" Minimum="4" Maximum="128" Value="16"
                      IsSnapToTickEnabled="True" TickFrequency="1"
                      ValueChanged="LengthSlider_ValueChanged"/>
            </Border>
          </Popup>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Character types card - answers "what characters may appear?" -->
    <Border Style="{StaticResource CardBorder}" Background="White">
      <StackPanel>
        <Border Style="{StaticResource CardHeader}">
          <TextBlock Text="CHARACTER TYPES" Style="{StaticResource CardHeaderText}"/>
        </Border>
        <StackPanel Style="{StaticResource CardContent}">
          <CheckBox x:Name="UppercaseCheckBox" Content="Uppercase (A-Z)" IsChecked="True" Margin="0,4"
                    Checked="CharacterOptionChanged" Unchecked="CharacterOptionChanged"/>
          <CheckBox x:Name="LowercaseCheckBox" Content="Lowercase (a-z)" IsChecked="True" Margin="0,4"
                    Checked="CharacterOptionChanged" Unchecked="CharacterOptionChanged"/>
          <CheckBox x:Name="DigitsCheckBox" Content="Digits (0-9)" IsChecked="True" Margin="0,4"
                    Checked="CharacterOptionChanged" Unchecked="CharacterOptionChanged"/>
          <CheckBox x:Name="SymbolsCheckBox" Content="Symbols (!@#$...)" IsChecked="True" Margin="0,4"
                    Checked="CharacterOptionChanged" Unchecked="CharacterOptionChanged"/>
          <CheckBox x:Name="ExcludeAmbiguousCheckBox" Content="Exclude ambiguous characters (l, 1, I, O, 0)" Margin="0,4"
                    Checked="CharacterOptionChanged" Unchecked="CharacterOptionChanged"/>
          <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock Text="Pool size" Style="{StaticResource DecisionLabel}" Width="90"/>
            <TextBlock x:Name="PoolSizeTextBlock" Style="{StaticResource DecisionValue}" Margin="6,0,0,0"/>
          </StackPanel>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Generation card - answers "how should the generator behave?" -->
    <Border Style="{StaticResource CardBorder}" Background="White" Margin="0,0,0,16">
      <StackPanel>
        <Border Style="{StaticResource CardHeader}">
          <TextBlock Text="GENERATION" Style="{StaticResource CardHeaderText}"/>
        </Border>
        <StackPanel Style="{StaticResource CardContent}">
          <CheckBox x:Name="AutoCopyCheckBox" Content="Copy on generate" Margin="0,4"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Action -->
    <Button x:Name="GenerateButton" Content="Generate" Width="130" Padding="0,8"
            HorizontalAlignment="Right" IsDefault="True" Click="GenerateButton_Click"/>

  </StackPanel>
</Window>
